{
  "name": "svg-path-editor",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Visual SVG path editor. Drag nodes, see the d attribute live.",
  "scripts": {
    "dev": "vite",
    "build": "svelte-check --tsconfig ./tsconfig.json && vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "devDependencies": {
    "@sveltejs/vite-plugin-svelte": "^4.0.2",
    "@tsconfig/svelte": "^5.0.4",
    "svelte": "^5.2.7",
    "svelte-check": "^4.1.0",
    "typescript": "^5.6.3",
    "vite": "^5.4.11",
    "vitest": "^2.1.5"
  },
  "license": "MIT"
}
